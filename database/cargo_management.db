CREATE TABLE sensor_data (
    sensor_id INTEGER PRIMARY KEY AUTOINCREMENT,
    cargo_id INTEGER,
    temperature DECIMAL(5,2),
    humidity DECIMAL(5,2),
    pressure DECIMAL(7,2),
    gas_value INTEGER,
    recorded_time DATETIME
);
